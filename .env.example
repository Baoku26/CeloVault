# ─── Celo RPC ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CELO_RPC=https://forno.celo.org

# ─── Agent wallet ─────────────────────────────────────────────────────────────
# These are used by the standalone agent process (agent/index.ts) only.
# On Vercel: do NOT set AGENT_PRIVATE_KEY — it is a backend secret for Railway.
AGENT_PRIVATE_KEY=0x
AGENT_WALLET_ADDRESS=0x

# ─── Agent config (optional overrides) ────────────────────────────────────────
AGENT_TARGET_RATE=1600
AGENT_MIN_SWAP_AMOUNT=1
AGENT_MAX_SWAP_AMOUNT=100
AGENT_SLIPPAGE_BPS=100
AGENT_INTERVAL_MS=60000
AGENT_AUTO_EXECUTE=false

# ─── WalletConnect ────────────────────────────────────────────────────────────
# Get from: https://cloud.reown.com → Create project → Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Railway agent URL ────────────────────────────────────────────────────────
# Set AFTER deploying agent to Railway. Format: https://xxx.railway.app
NEXT_PUBLIC_AGENT_API_URL=

# ─── ERC-8004 ─────────────────────────────────────────────────────────────────
# Set AFTER running: pnpm agent-register-mainnet
AGENT_ID=

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
# Get from: https://app.pinata.cloud → API Keys → New Key → Admin → Copy JWT
PINATA_JWT=

# ─── Cached agent card URI (skip re-upload on retry) ─────────────────────────
CACHED_AGENT_URI=ipfs://QmdjbPzzAJFCdQ6TcnzNkiWycoP17EBdU9jNDVxc1tqgBj
